+    const __m128i summed_i32_h = _mm_madd_epi16(ones_i16, summed_i16_h);
+
+    const __m256i summed_i32 = MM256_SET_M128I(summed_i32_h, summed_i32_l);
+
+    __m256 f_vector = _mm256_cvtepi32_ps(summed_i32);
+
+    __m256 v_scale = _mm256_set1_ps(scale);
+    return _mm256_mul_ps(f_vector, v_scale);
