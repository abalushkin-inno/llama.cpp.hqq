+void quantize_row_q4_hqq_ref(const float * GGML_RESTRICT x, block_q4_hqq * GGML_RESTRICT y, int64_t k) {
+    static const int qk = QK4_HQQ;
+
+    assert(k % qk == 0);
+
+    const int nb = k / qk;
+
+    for (int i = 0; i < nb; i++) {
+        float min = x[i*qk]; // absolute max
+        float max = x[i*qk];
+
+        for (int j = 1; j < qk; j++) {
+            const float v = x[i*qk + j];
+            if (max < v)
+                max  = v;
+
+            if (min > v)
+                min = v;
+        }
+
+        const float scale  = (max - min) / 15.0f;
+        const float iscale = scale ? 1.0f/scale : 0.0f;
+
+        const float zero  = - min * iscale;
+
+        y[i].scale = GGML_FP32_TO_FP16(scale);
+        y[i].zero = GGML_FP32_TO_FP16(zero);
+
+        for (int j = 0; j < qk/2; ++j) {
+            const float x0 = (x[i*qk + 0    + j])*iscale + zero;
+            const float x1 = (x[i*qk + qk/2 + j])*iscale + zero;
+
+            const uint8_t xi0 = MAX(0, (MIN(15, (int8_t)(x0 + 0.5f))));
+            const uint8_t xi1 = MAX(0, (MIN(15, (int8_t)(x1 + 0.5f))));
+
+            y[i].qs[j]  = xi0;
+            y[i].qs[j] |= xi1 << 4;
+        }
+    }
+}
